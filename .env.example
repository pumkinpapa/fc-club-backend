# ─── 서버 설정 ───
APP_NAME=FC동호회
SECRET_KEY=your-secret-key-change-this-to-random-string
DATABASE_URL=sqlite:///./fc_club.db

# ─── 솔라피 (Solapi) 설정 ───
# https://solapi.com > 설정 > API Key 관리에서 발급
SOLAPI_API_KEY=your-solapi-api-key
SOLAPI_API_SECRET=your-solapi-api-secret
# 솔라피에 등록한 발신번호 (사전 등록 필요)
SOLAPI_SENDER_PHONE=01012345678
# 카카오 채널 연동 후 발급받은 PFID
SOLAPI_PFID=your-kakao-pfid
# 알림톡 템플릿 코드 (솔라피에서 등록 후 검수 완료된 코드)
SOLAPI_TEMPLATE_VOTE=MATCH_VOTE
SOLAPI_TEMPLATE_RESULT=MATCH_RESULT

# ─── 카카오 로그인 설정 ───
# https://developers.kakao.com > 내 애플리케이션에서 발급
KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret
KAKAO_REDIRECT_URI=http://localhost:8000/api/auth/kakao/callback

# ─── 경기 설정 ───
# 매주 경기 요일 (0=월, 6=일)
MATCH_DAY_OF_WEEK=6
# 투표 알림 발송 요일 (0=월, 6=일)
VOTE_NOTIFY_DAY=2
# 투표 알림 발송 시간 (24시간 형식)
VOTE_NOTIFY_HOUR=10
VOTE_NOTIFY_MINUTE=0
